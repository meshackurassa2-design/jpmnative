      const encrypted = await encryptMessage(content, getSharedSecret(user.id, id))
      await supabase.from('messages').insert({
        sender_id: user.id,
        receiver_id: id,
        content: encrypted,
        is_shop_chat: true,
        is_offer: true,
        offer_amount: parseFloat(make_offer),
