          "androidAppId": "ca-app-pub-4939768656689626~2505670868",
          "iosAppId": "ca-app-pub-8166782428171770~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc0498f6-2882-418a-8467-17df2bfbf8d6"
      }
    },
    "owner": "dapazcm"
