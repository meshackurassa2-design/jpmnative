{
  "expo": {
    "name": "JPM",
    "slug": "jpm-socialmarket",
    "version": "6.0.1",
    "newArchEnabled": false,
    "orientation": "portrait",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
